{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "node",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": ".tsc-out",
    "noEmit": true,
    "types": ["node"]
  },
  "include": ["api/**/*.ts", "api/**/*.tsx", "app/**/*.ts", "app/**/*.tsx"]
}
