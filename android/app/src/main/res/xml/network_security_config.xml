<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
    <!-- Allow cleartext to the VPS IP for fallback -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">216.238.111.253</domain>
    </domain-config>
    <!-- Allow cleartext to the VPS domain -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">vps.agrorumo.com</domain>
    </domain-config>
</network-security-config>
