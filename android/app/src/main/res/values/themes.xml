<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.RumoAgente" parent="android:Theme.Material.NoActionBar">
        <!-- Dark background matching iOS #0D1117 -->
        <item name="android:colorBackground">@color/dark_bg</item>
        <item name="android:windowBackground">@color/dark_bg</item>

        <!-- Edge-to-edge: transparent system bars, content draws behind -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:enforceNavigationBarContrast">false</item>
        <item name="android:enforceStatusBarContrast">false</item>

        <!-- No action bar / title bar -->
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>

        <!-- Translucent navigation for gesture nav -->
        <item name="android:navigationBarDividerColor">@android:color/transparent</item>

        <!-- Text colors -->
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_subtle</item>
        <item name="android:textColorHint">@color/text_subtle</item>

        <!-- Accent / primary color for widgets -->
        <item name="android:colorAccent">@color/accent</item>
        <item name="android:colorPrimary">@color/accent</item>
        <item name="android:colorPrimaryDark">@color/accent_dark</item>
    </style>

    <!-- Splash / launch theme (shown before Compose loads) -->
    <style name="Theme.RumoAgente.Splash" parent="Theme.RumoAgente">
        <item name="android:windowBackground">@color/secondary_dark</item>
    </style>
</resources>
